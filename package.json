{
  "name": "florida-politics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && rsync -a --delete dist/ ../spoonerlabs-site/florida-politics/",
    "data:fetch-legislature": "tsx scripts/fetch_legislature.ts",
    "data:fetch-elections": "tsx scripts/fetch_elections.ts",
    "data:fetch-zips": "tsx scripts/fetch_election_zips.ts",
    "data:parse-legislature": "tsx scripts/parse_legislature.ts",
    "data:parse-elections": "tsx scripts/parse_elections.ts",
    "data:normalize": "tsx scripts/normalize.ts",
    "data:build": "tsx scripts/build_data.ts",
    "data:all": "npm run data:fetch-legislature && npm run data:parse-legislature && npm run data:fetch-elections && npm run data:fetch-zips && npm run data:parse-elections && npm run data:normalize && npm run data:build"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^22.0.0",
    "@types/topojson-client": "^3.1.4",
    "playwright": "^1.49.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "cheerio": "^1.0.0",
    "csv-parse": "^5.6.0",
    "unzipper": "^0.12.3",
    "@types/unzipper": "^0.10.10"
  }
}
